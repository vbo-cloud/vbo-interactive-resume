{
  "name": "interactive-resume-template",
  "version": "1.0.0",
  "description": "An open-source interactive resume template. Clone it, fill in your info, deploy it.",
  "homepage": "https://clementbouly.github.io/interactive-resume-template/",
  "repository": {
    "type": "git",
    "url": "https://github.com/clementbouly/interactive-resume-template.git"
  },
  "keywords": [
    "resume",
    "cv",
    "template",
    "react",
    "typescript",
    "portfolio",
    "interactive",
    "tailwindcss",
    "vite",
    "open-source"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:pdf && vite",
